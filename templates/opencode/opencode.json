{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-84a8a243-4067-44b5-83a2-b66002adbbef"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "duckdb": {
      "command": [
        "uvx",
        "mcp-server-motherduck",
        "--db-path",
        ":memory:",
        "--read-write",
        "--allow-switch-databases"
      ],
      "enabled": true,
      "type": "local"
    },
    "firecrawl": {
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "enabled": true,
      "environment": {
        "FIRECRAWL_API_KEY": "fc-c449f119086a4f8d95a2ca9b27d5d554"
      },
      "type": "local"
    },
    "lean-ctx": {
      "command": [
        "/Users/pid-alvian/.local/bin/lean-ctx"
      ],
      "enabled": true,
      "environment": {
        "LEAN_CTX_DATA_DIR": "/Users/pid-alvian/.config/lean-ctx"
      },
      "type": "local"
    },
    "mcp-mermaid": {
      "command": [
        "npx",
        "-y",
        "mcp-mermaid"
      ],
      "enabled": true,
      "type": "local"
    },
    "metabase-staging": {
      "command": [
        "npx",
        "-y",
        "@imlewc/metabase-server"
      ],
      "enabled": false,
      "environment": {
        "METABASE_PASSWORD": "Qweqweq123!",
        "METABASE_URL": "https://reporting-testing.tapinsure.io",
        "METABASE_USERNAME": "alvian.hanif@pasarpolis.com"
      },
      "type": "local"
    },
    "metabase": {
      "command": [
        "npx",
        "-y",
        "@imlewc/metabase-server"
      ],
      "enabled": false,
      "environment": {
        "METABASE_PASSWORD": "Qweqweq123!",
        "METABASE_URL": "https://reporting-testing.tapinsure.io",
        "METABASE_USERNAME": "alvian.hanif@pasarpolis.com"
      },
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "type": "local"
    },
    "serena": {
      "command": [
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd",
        "--enable-web-dashboard",
        "false",
        "--open-web-dashboard",
        "false"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [
    "@warp-dot-dev/opencode-warp@0.1.5",
    "opencode-handoff@0.5.0"
  ],
  "agent": {
    "planner": {
      "description": "Understand and document tasks before any coding",
      "mode": "all",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./skills/planner/SKILL.md}",
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": "allow"
      }
    },
    "coder": {
      "description": "Implement code changes incrementally per task documentation",
      "mode": "all",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./skills/coder/SKILL.md}"
    },
    "reviewer": {
      "description": "Review diffs for correctness, risks, and consistency",
      "mode": "all",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./skills/reviewer/SKILL.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "tester": {
      "description": "Execute test plans and verify behavior",
      "mode": "all",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./skills/tester/SKILL.md}",
      "permission": {
        "bash": "allow"
      }
    },
    "analyzer": {
      "description": "Investigate issues, trace code paths, and analyze logs",
      "mode": "all",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./skills/analyzer/SKILL.md}",
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": "allow"
      }
    }
  },
  "shell": "/bin/zsh",
  "tools": {
    "auto_call": true,
    "prefer_mcp": true
  }
}
